                <div class="flex-h">
                    <p class="card-text">Disponível: </p>
                    <p class="card-text" id="storage-free-display">@SystemStatsFormatter.FormatDisk(MonitorManager.Stats.DiskFreeMb)</p>
                </div>
            </div>
        </div>
